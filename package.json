{
  "name": "ai-saas-template",
  "version": "1.0.0",
  "description": "AI SaaS Template",
  "author": "gegarron <gejialun88@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/geallenboy/ai-saas-template",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "build:docker": "vite build",
    "start": "node scripts/preview-server.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run --passWithNoTests",
    "test:dev": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:watch": "vitest --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "db:generate": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit studio",
    "db:push": "NODE_TLS_REJECT_UNAUTHORIZED=0 drizzle-kit push",
    "prepare": "husky || true",
    "ci": "pnpm run type-check && pnpm run lint:check && pnpm run test",
    "fix:all": "node scripts/fix-code-standards.js",
    "fix:keys": "node scripts/batch-fix-react-keys.js",
    "fix:quick": "pnpm lint && pnpm format",
    "quality:check": "pnpm run type-check && pnpm run lint:check && pnpm run format:check && pnpm run test:coverage",
    "quality:fix": "pnpm run format && pnpm run lint && pnpm run test",
    "deps:check": "pnpm outdated",
    "deps:update": "pnpm update --latest",
    "test:unit": "vitest run --reporter=verbose --passWithNoTests",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-day-picker": "^9.7.0",
    "react-dom": "^19.1.0",
    "react-error-boundary": "^6.1.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.5",
    "web-vitals": "^5.0.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "glob": "^11.0.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vite": "^6.4.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": [
      "biome check --apply --no-errors-on-unmatched"
    ]
  }
}
